generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  phone       String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]
  candidates  Candidate[]
  tags        Tag[]
  vacancies   Vacancy[]
  emailConfig EmailConfig?
  wahaConfig  WahaConfig?
}

model User {
  id              Int            @id @default(autoincrement())
  email           String         @unique
  name            String?
  passwordHash    String
  role            UserRole       @default(CLIENT)
  clientId        Int?
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdCandidates Candidate[]  @relation("CreatedBy")
  uploadedCandidates Candidate[] @relation("UploadedBy")
  ownedCandidates   Candidate[]  @relation("OwnedCandidates")
  createdVacancies    Vacancy[]            @relation("CreatedVacancy")
  assignedCandidates CandidateVacancy[]   @relation("AssignedCandidateVacancy")
  notes             Note[]
  activities        ActivityLog[]
}

enum UserRole {
  ADMIN
  CLIENT
}

model Candidate {
  id           Int             @id @default(autoincrement())
  name         String?
  email        String          @unique
  phone        String          @unique
  address      String?
  education    String?
  experience   String?
  skills       String[]
  courses      String?
  cvSummary    String?
  source       CandidateSource
  cvFilePath   String?
  rawText      String?
  status       CandidateStatus @default(NEW)
  observations String?

  clientId    Int
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ownerId     Int?
  owner       User?           @relation("OwnedCandidates", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById Int?
  createdBy   User?           @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  uploadedById Int?
  uploadedBy  User?           @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tags        Tag[]
  notes       Note[]
  activities  ActivityLog[]
  vacancies   CandidateVacancy[]
}

enum CandidateSource {
  WHATSAPP
  EMAIL
  UPLOAD
}

enum CandidateStatus {
  NEW
  REVIEWED
  CONTACTED
  REJECTED
  HIRED
}

model Tag {
  id         Int         @id @default(autoincrement())
  name       String
  color      String      @default("#3b82f6")
  prompt     String?
  clientId   Int
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  candidates Candidate[]

  @@unique([name, clientId])
}

model Note {
  id          Int       @id @default(autoincrement())
  content     String
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  action      String
  details     String?
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model EmailConfig {
  id          Int       @id @default(autoincrement())
  clientId    Int       @unique
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider    String    @default("CUSTOM")
  host        String
  port        Int       @default(993)
  userEmail   String
  password    String
  useTls      Boolean   @default(true)
  isActive    Boolean   @default(true)
  lastChecked DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WahaConfig {
  id          Int       @id @default(autoincrement())
  clientId    Int       @unique
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  apiUrl      String
  apiKey      String?
  sessionName String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum VacancyStatus {
  OPEN
  CLOSED
  PAUSED
}

enum CandidateVacancyStage {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model Vacancy {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?
  requirements String?
  location     String?
  modality     String?
  salaryMin    Int?
  salaryMax    Int?
  status       VacancyStatus @default(OPEN)
  closedAt     DateTime?

  clientId    Int
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdById Int?
  createdBy   User?        @relation("CreatedVacancy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  candidates CandidateVacancy[]
}

model CandidateVacancy {
  candidateId  Int
  vacancyId    Int
  stage        CandidateVacancyStage @default(NEW)
  assignedAt   DateTime     @default(now())
  assignedById Int?
  assignedBy   User?        @relation("AssignedCandidateVacancy", fields: [assignedById], references: [id], onDelete: SetNull)
  notes        String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancy   Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@id([candidateId, vacancyId])
}
